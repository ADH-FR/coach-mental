---
import { getCollection } from "astro:content";
import { getCategoryLabel, getCategoryColor } from "../../utils/categories";
import BaseLayout from "../../layouts/BaseLayout.astro";

export async function getStaticPaths() {
  const posts = await getCollection("posts");
  const categories = [...new Set(posts.map(p => p.data.category).filter(Boolean))];
  return categories.map(category => ({ params: { category } }));
}

const { category } = Astro.params;

const posts = (await getCollection("posts"))
  .filter(p => p.data.category === category)
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());

const label = getCategoryLabel(category);
const color = getCategoryColor(category);
---

<BaseLayout title={`${label} — Coach'in Mental`}>
  <div class="cat-page">

    <header class="cat-header">
      <span class="cat-badge" style={`background-color: ${color}`}>{label}</span>
      <h1 class="cat-title">{label}</h1>
      <p class="cat-count">{posts.length} article{posts.length > 1 ? 's' : ''}</p>
    </header>

    <div class="posts-list">
      {posts.map(post => (
        <article class="post-row">
          {post.data.image && (
            <img src={post.data.image} alt={post.data.title} class="post-thumb" />
          )}
          <div class="post-body">
            <time datetime={post.data.pubDate.toISOString()}>
              {post.data.pubDate.toLocaleDateString('fr-FR', { day: 'numeric', month: 'long', year: 'numeric' })}
            </time>
            <h2>
              <a href={`/blog/${post.id.replace(/\.md$/, '')}/`} class="post-link">
                {post.data.title}
              </a>
            </h2>
            {post.data.description && (
              <p class="post-desc">{post.data.description}</p>
            )}
          </div>
        </article>
      ))}
    </div>

  </div>
</BaseLayout>

<style>
.cat-page {
  max-width: 860px;
  margin: 0 auto;
  padding: 2rem 0;
}

/* En-tête de catégorie */
.cat-header {
  margin-bottom: 2.5rem;
  padding-bottom: 1.5rem;
  border-bottom: 2px solid var(--color-border);
}

.cat-badge {
  display: inline-block;
  color: white;
  font-size: 0.65rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.06em;
  padding: 2px 8px;
  border-radius: 4px;
  margin-bottom: 0.6rem;
}

.cat-title {
  font-size: 2rem;
  font-weight: 700;
  line-height: 1.2;
  margin-bottom: 0.3rem;
}

.cat-count {
  font-size: 0.9rem;
  color: var(--color-muted);
}

/* Liste d'articles */
.posts-list {
  display: flex;
  flex-direction: column;
  gap: 0;
}

.post-row {
  position: relative;
  display: flex;
  flex-direction: row;
  gap: 1.25rem;
  align-items: flex-start;
  padding: 1.5rem 0;
  border-bottom: 1px solid var(--color-border);
}

.post-thumb {
  width: 200px;
  height: 130px;
  flex-shrink: 0;
  object-fit: cover;
  border-radius: 8px;
}

.post-body {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 0.35rem;
}

.post-body time {
  font-size: 0.8rem;
  color: var(--color-muted);
}

.post-row h2 {
  font-size: 1.1rem;
  line-height: 1.35;
}

.post-link {
  color: var(--color-text);
  text-decoration: none;
}

.post-link::after {
  content: '';
  position: absolute;
  inset: 0;
}

.post-link:hover {
  color: var(--color-accent);
}

.post-desc {
  font-size: 0.9rem;
  color: var(--color-muted);
  line-height: 1.5;
}

@media (max-width: 768px) {
  .cat-title {
    font-size: 1.5rem;
  }

  .post-row {
    flex-direction: column;
  }

  .post-thumb {
    width: 100%;
    height: 180px;
  }
}
</style>
