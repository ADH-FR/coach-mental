---
import { getCollection } from 'astro:content';
import { getCategoryLabel, getCategoryColor } from "../../utils/categories";
import BaseLayout from "../../layouts/BaseLayout.astro";

const posts = await getCollection('posts');
---

<BaseLayout title="Blog">
  <h1 class="page-title">Blog de Coach'In Mental</h1>

  <div class="posts-grid">
  {posts.map((post) => (
    <article class="post-card">
      {post.data.image && (
        <div class="card-image-wrapper">
          <img src={post.data.image} alt={post.data.title} class="card-image" />
        </div>
      )}
      <div class="card-content">
        <h2>
          <a href={`/blog/${post.id.replace(/\.md$/, '')}/`} class="card-link">
            {post.data.title}
          </a>
        </h2>
        <p>{post.data.description}</p>
        <span>{post.data.pubDate.toLocaleDateString()}</span>
        {post.data.category && (
          <a href={`/category/${post.data.category}`} class="category" style={`background-color: ${getCategoryColor(post.data.category)}`}>
            {getCategoryLabel(post.data.category)}
          </a>
        )}
      </div>
    </article>
  ))}
</div>
</BaseLayout>

<style is:global>

.page-title {
  text-align: center;
  margin-bottom: 2rem;
}

/* GRID */
.posts-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
  gap: 30px;
  align-items: stretch; /* ?? important */
}

/* CARD */
.post-card {
  position: relative;
  display: flex;
  flex-direction: column;
  border-radius: 16px;
  overflow: hidden;
  background: #ffffff;
  border: 1px solid var(--color-border);
  transition: all 0.25s ease;
  height: 100%;
}
/* TITRE */
.post-card h2 {
  font-size: 1.2rem;
  margin-bottom: 0.5rem;
  line-height: 1.4;
}
/* DESCRIPTION */
.post-card p {
  color: var(--color-muted);
  margin-bottom: 0.8rem;
}
/* DATE */
.post-card span {
  font-size: 0.8rem;
  color: var(--color-muted);
}

/* IMAGE */
.card-image {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.4s ease;
}
/* IMAGE WRAPPER (ratio fixe) */
.card-image-wrapper {
  position: relative;
  width: 100%;
  aspect-ratio: 16 / 9;
  overflow: hidden;
  display: block; /* ?? important */
}
/* CONTENT */
.card-content {
  padding: 1.2rem;
  flex-grow: 1;
}
/* stretched link — rend toute la card cliquable */
.card-link {
  color: inherit;
  text-decoration: none;
}
.card-link::after {
  content: '';
  position: absolute;
  inset: 0;
}

/* couleur injectée en inline style */
.category {
  position: relative;
  z-index: 1;
  color: white;
  padding: 4px 8px;
  font-size: 12px;
  border-radius: 4px;
}

/* SHADOW PREMIUM */
.post-card:hover {
  transform: translateY(-6px);
  box-shadow: 0 25px 50px rgba(0,0,0,0.08);
}
/* HOVER ZOOM */
.post-card:hover .card-image {
  transform: scale(1.05);
}

/* TITRE */
.post-card h2 {
  margin-bottom: 0.5rem;
  font-size: 1.2rem;
}

/* DESCRIPTION */
.post-card p {
  color: var(--color-muted);
  margin-bottom: 0.8rem;
}

/* DATE */
.post-card span {
  font-size: 0.8rem;
  color: var(--color-muted);
}
/* MOBILE */
@media (max-width: 768px) {
  .card-image-wrapper {
    aspect-ratio: 1 / 1;
  }

  .post-card h2 {
    font-size: 1rem;
  }

  .post-card p {
    font-size: 0.9rem;
  }
}

/* GRAND ECRAN */
@media (min-width: 1200px) {
  .posts-grid {
    grid-template-columns: repeat(3, 1fr);
  }
}
</style>