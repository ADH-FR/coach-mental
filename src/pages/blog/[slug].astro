---
import { getCollection, render } from 'astro:content';
import { getCategoryLabel, getCategoryColor } from "../../utils/categories";
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('posts');
  return posts.map(post => ({
    params: { slug: post.id.replace(/\.md$/, '') },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const categoryLabel = post.data.category ? getCategoryLabel(post.data.category) : null;
const categoryColor = post.data.category ? getCategoryColor(post.data.category) : null;
const dateStr = post.data.pubDate.toLocaleDateString('fr-FR', {
  day: 'numeric', month: 'long', year: 'numeric'
});
---

<BaseLayout title={post.data.title}>
  <div class="article-wrap">

    {post.data.image && (
      <img src={post.data.image} alt={post.data.title} class="cover-image" />
    )}

    <h1>{post.data.title}</h1>

    <p class="meta">
      <time datetime={post.data.pubDate.toISOString()} class="date">{dateStr}</time>
      {categoryLabel && (
        <>
          <span class="sep">|</span>
          <a href={`/category/${post.data.category}`} class="cat-link" style={`color: ${categoryColor}`}>
            {categoryLabel}
          </a>
        </>
      )}
    </p>

    <hr class="divider" />

    <div class="content">
      <Content />
    </div>

  </div>
</BaseLayout>

<style>
.article-wrap {
  max-width: 720px;
  margin: 0 auto;
  padding: 2rem 1rem 4rem;
}

/* IMAGE */
.cover-image {
  width: 100%;
  height: auto;
  aspect-ratio: 3 / 2;
  object-fit: cover;
  border-radius: 8px;
  display: block;
}
/* TITRE (template) — le h1 du markdown est masqué ci-dessous */
h1 {
  font-size: 1.4rem;
  line-height: 1.3;
  text-align: center;
  margin-top: 1.5rem;
  margin-bottom: 0.75rem;
}

/* MÉTA */
.meta {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 0.5rem;
  font-size: 0.9rem;
  margin-bottom: 1.25rem;
}

.date {
  color: #7B3F00;
  font-weight: 500;
}

.sep {
  color: var(--color-muted);
}

.cat-link {
  font-weight: 600;
  text-decoration: none;
}

.cat-link:hover {
  text-decoration: underline;
}

/* SÉPARATEUR */
.divider {
  border: none;
  border-top: 1px solid var(--color-border);
  margin: 0 0 2rem;
}


@media (max-width: 768px) {
  .cover-image {
    height: 220px;
  }

  h1 {
    font-size: 1.2rem;
  }
}
</style>
